<launch>



  <param name="robot_description" textfile="$(find clpai_12dof_0905)/urdf/clpai_12dof_0905.urdf" />
  <node
    name="joint_state_publisher_gui"
    pkg="joint_state_publisher_gui"
    type="joint_state_publisher_gui" >
  <!-- <remap from="joint_states" to="/motor_goals" /> -->
  <remap from="joint_states" to="/joint_goals" />
  </node>
  <node
    name="robot_state_publisher"
    pkg="robot_state_publisher"
    type="robot_state_publisher" />
  <node
    name="rviz"
    pkg="rviz"
    type="rviz"
    args="-d $(find clpai_12dof_0905)/rviz/display.rviz" />
</launch>